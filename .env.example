# =============================================================================
# LOCAL DEV TEMPLATE
# =============================================================================
# This file is the template for LOCAL DEVELOPMENT only. Local .env files
# (backend/.env and frontend/.env) must point at the dev Supabase project
# (`inventorypp-dev`), never at prod.
#
# Production credentials live ONLY in the Koyeb (backend) and Vercel (frontend)
# dashboards. Never copy them into a file in this repo.
#
# WARNING: VITE_* variables are inlined into the frontend bundle at build time
# and are publicly visible. Only put publishable keys here, never secret keys.
# =============================================================================

# Backend (loaded by backend/app/config.py via pydantic-settings)
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SECRET_KEY=sb_secret_...
CORS_ORIGINS=http://localhost:5173

# Frontend (loaded by Vite, baked into the bundle at build time)
VITE_SUPABASE_URL=https://xxxxx.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
VITE_API_BASE_URL=http://localhost:8000/api/v1

# Direct Postgres connection string for scripts ONLY (NOT loaded by the app).
# Used by scripts/apply_migrations.sh as TARGET_DATABASE_URL=...
# Append ?sslmode=require and use port 5432, NOT the pooler port 6543.
# DATABASE_URL=postgresql://postgres:password@db.xxxxx.supabase.co:5432/postgres?sslmode=require
